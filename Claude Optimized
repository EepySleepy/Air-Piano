import cv2
import mediapipe as mp
import time
import threading

cap = cv2.VideoCapture(0)
cap.set(cv2.CAP_PROP_BUFFERSIZE, 1)

mpHands = mp.solutions.hands
hands = mpHands.Hands(
    static_image_mode=False,
    max_num_hands=2,
    min_detection_confidence=0.7,
    min_tracking_confidence=0.5,
    model_complexity=0
)

latest_frame = None
latest_results = None
frame_lock = threading.Lock()
results_lock = threading.Lock()
new_frame_event = threading.Event()  # thread sleeps until a new frame arrives

def process_hands():
    global latest_results
    while True:
        new_frame_event.wait()        # sleep until main loop signals a new frame
        new_frame_event.clear()

        with frame_lock:
            frame = latest_frame.copy()  # copy HERE in the thread, not the main loop

        imgRGB = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        results = hands.process(imgRGB)

        with results_lock:
            latest_results = results

thread = threading.Thread(target=process_hands, daemon=True)
thread.start()

pTime = 0
tipID = [4, 8, 12, 16, 20]

while True:
    success, img = cap.read()
    if not success:
        break

    img = cv2.flip(img, 1)

    with frame_lock:
        latest_frame = img          # store reference
    new_frame_event.set()           # wake the thread

    with results_lock:
        results = latest_results

    if results and results.multi_hand_landmarks:
        for handLms in results.multi_hand_landmarks:
            lmList = []
            h, w, c = img.shape
            for id, lm in enumerate(handLms.landmark):
                cx, cy = int(lm.x * w), int(lm.y * h)
                lmList.append([id, cx, cy])
                if id in tipID:
                    cv2.circle(img, (cx, cy), 5, (255, 0, 0), cv2.FILLED)

            if len(lmList) == 21:
                fingers = []
                for fingerid in range(5):
                    if lmList[tipID[fingerid]][2] < lmList[tipID[fingerid] - 2][2]:
                        fingers.append(1)
                    else:
                        fingers.append(0)
                print(fingers)

    cTime = time.time()
    fps = 1 / (cTime - pTime)
    pTime = cTime

    cv2.putText(img, f"FPS: {int(fps)}", (10, 70), cv2.FONT_HERSHEY_SIMPLEX, 1, (255, 0, 255), 2)
    cv2.imshow("Hand Tracking", img)

    if cv2.waitKey(1) & 0xFF == ord('q'):
        break

cap.release()
cv2.destroyAllWindows()
